{
  "name": "inventory-list-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "react-app",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix react-app run dev",
    "dev:api": "npm --prefix backend run dev",
    "qa:up": "docker compose -f docker-compose.qa.yml up -d --build",
    "qa:down": "docker compose -f docker-compose.qa.yml down",
    "qa:logs": "docker compose -f docker-compose.qa.yml logs -f",
    "qa:reset": "node scripts/qa-reset-danger.mjs",
    "qa:reset:danger": "node scripts/qa-reset-danger.mjs",
    "qa:test": "playwright test --config=playwright.qa.config.mjs",
    "qa:test:headed": "playwright test --config=playwright.qa.config.mjs --headed",
    "build:frontend": "npm --prefix react-app run build",
    "check:packet": "node --test scripts/packet-parser.test.mjs",
    "check:search": "node --test scripts/search.test.mjs",
    "check:api": "npm --prefix backend run check",
    "check:static": "node --check ocr.js && node --check script.js && node --check admin.js",
    "check": "npm run check:static && npm run check:api && npm run check:packet && npm run check:search && npm run build:frontend"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
