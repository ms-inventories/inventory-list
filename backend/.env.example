NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://inventory:inventory@localhost:5432/inventory

# Tenant routing
BASE_DOMAIN=876en.org
PUBLIC_APP_URL=https://876en.org

# Local-only auth bypass for development. Do not enable in production.
ALLOW_DEV_AUTH=true
# Number of trusted reverse proxies in front of the API. Coolify normally uses one.
TRUST_PROXY_HOPS=1

# Authentik OIDC provider values
OIDC_CLIENT_ID=<authentik inventory client id>
OIDC_ISSUER=https://auth.876en.org/application/o/inventory-web/
OIDC_AUDIENCE=<authentik inventory client id>
OIDC_DISCOVERY_URL=https://auth.876en.org/application/o/inventory-web/.well-known/openid-configuration
OIDC_GROUPS_CLAIM=groups
PLATFORM_ADMIN_GROUP=876en-admins
FRG_ADMIN_GROUP=876en-frg-admins
TENANT_ADMIN_GROUP=876en-platoon-admin
TENANT_GROUP_PREFIX=876en-
AUTHENTIK_TENANT_GROUP_FALLBACK_ENABLED=true
# Optional first/root admin fallback. Authenticated users with these emails
# are platform admins even before Authentik groups are fully wired.
# Required in production so you cannot lock yourself out on day one.
PLATFORM_ADMIN_EMAILS=supply@example.com
# Optional stable Authentik OIDC subject fallback for root/support admins.
# Use this when Authentik is not emitting email or group claims yet.
PLATFORM_ADMIN_SUBJECTS=

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=https://876en.org,https://api.876en.org,http://localhost:5173

# Local NAS storage. Mount the NAS/share into the backend container at STORAGE_ROOT.
STORAGE_DRIVER=local
STORAGE_ROOT=/data/inventory-uploads
PUBLIC_MEDIA_BASE_URL=https://api.876en.org/media
# Required in production. Generate at least 32 random bytes and store them as base64.
MEDIA_SIGNING_SECRET=<base64-encoded 32-byte-or-longer random secret>
# HttpOnly tenant media-session lifetime; renewed by authorized API activity.
MEDIA_SESSION_TTL_SECONDS=300
# Unattached photo uploads expire after this many hours and may be purged.
MEDIA_UPLOAD_STAGING_TTL_HOURS=24

# One-time, session-scoped crew access. Use a dedicated random base64 secret in production.
CREW_ACCESS_SECRET=<base64-encoded 32-byte-or-longer random secret>
CREW_GRANT_TTL_HOURS=168
CREW_MAX_ACTIVE_GRANTS_PER_SESSION=25
# Limits unfinished uploads for one temporary login; attached proof no longer counts.
CREW_MAX_STAGED_UPLOADS_PER_SESSION=12
# A correct invite token is retired after this many wrong PIN attempts, across its full lifetime.
CREW_MAX_FAILURES_PER_GRANT=5
CREW_MAX_FAILURES_PER_WINDOW=5
CREW_MAX_TENANT_FAILURES_PER_WINDOW=100
CREW_FAILURE_WINDOW_MINUTES=15

# Brevo SMTP for welcome/invite emails.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=876 EN Inventory
EMAIL_FROM_ADDRESS=no-reply@876en.org
