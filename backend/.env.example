NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://inventory:inventory@localhost:5432/inventory

# Tenant routing
BASE_DOMAIN=876en.org

# Local-only auth bypass for development. Do not enable in production.
ALLOW_DEV_AUTH=true

# Authentik OIDC provider values
OIDC_ISSUER=https://auth.876en.org/application/o/inventory/
OIDC_AUDIENCE=inventory-api
OIDC_DISCOVERY_URL=https://auth.876en.org/application/o/inventory/.well-known/openid-configuration
OIDC_GROUPS_CLAIM=groups
PLATFORM_ADMIN_GROUP=inventory-platform-admins

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=https://876en.org,https://api.876en.org,http://localhost:5173

# Local NAS storage. Mount the NAS/share into the backend container at STORAGE_ROOT.
STORAGE_DRIVER=local
STORAGE_ROOT=/data/inventory-uploads
PUBLIC_MEDIA_BASE_URL=https://api.876en.org/media

# Brevo SMTP for welcome/invite emails.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=876 EN Inventory
EMAIL_FROM_ADDRESS=no-reply@876en.org
