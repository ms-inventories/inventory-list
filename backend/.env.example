NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://inventory:inventory@localhost:5432/inventory

# Tenant routing
BASE_DOMAIN=inventory.bensonhub.com

# Local-only auth bypass for development. Do not enable in production.
ALLOW_DEV_AUTH=true

# Authentik OIDC provider values
OIDC_ISSUER=https://auth.bensonhub.com/application/o/inventory/
OIDC_AUDIENCE=inventory-api
OIDC_DISCOVERY_URL=https://auth.bensonhub.com/application/o/inventory/.well-known/openid-configuration
OIDC_GROUPS_CLAIM=groups
PLATFORM_ADMIN_GROUP=inventory-platform-admins

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=https://inventory.bensonhub.com,http://localhost:5173
