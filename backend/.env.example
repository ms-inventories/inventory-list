NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://inventory:inventory@localhost:5432/inventory

# Tenant routing
BASE_DOMAIN=876en.org
PUBLIC_APP_URL=https://876en.org

# Local-only auth bypass for development. Do not enable in production.
ALLOW_DEV_AUTH=true

# Authentik OIDC provider values
OIDC_ISSUER=https://auth.876en.org/application/o/inventory-web/
OIDC_AUDIENCE=<authentik inventory client id>
OIDC_DISCOVERY_URL=https://auth.876en.org/application/o/inventory-web/.well-known/openid-configuration
OIDC_GROUPS_CLAIM=groups
PLATFORM_ADMIN_GROUP=876en-admins
FRG_ADMIN_GROUP=876en-frg-admins
TENANT_ADMIN_GROUP=876en-platoon-admin
TENANT_GROUP_PREFIX=876en-
# Optional first/root admin fallback. Authenticated users with these emails
# are platform admins even before Authentik groups are fully wired.
# Required in production so you cannot lock yourself out on day one.
PLATFORM_ADMIN_EMAILS=supply@example.com

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=https://876en.org,https://api.876en.org,http://localhost:5173

# Local NAS storage. Mount the NAS/share into the backend container at STORAGE_ROOT.
STORAGE_DRIVER=local
STORAGE_ROOT=/data/inventory-uploads
PUBLIC_MEDIA_BASE_URL=https://api.876en.org/media

# Brevo SMTP for welcome/invite emails.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=876 EN Inventory
EMAIL_FROM_ADDRESS=no-reply@876en.org
